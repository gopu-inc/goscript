# ============================================
# Goscript Language Configuration
# ============================================

# Goscript language files
*.gjs linguist-language=Goscript linguist-detectable=true linguist-color=#7c3aed
*.gos linguist-language=Goscript linguist-detectable=true linguist-color=#7c3aed

# Configuration pour le diff
*.gjs diff=goscript
*.gjs merge=goscript

# ============================================
# Grammaires et configurations (exclure des stats)
# ============================================

# Grammaires TextMate - ne pas compter comme Goscript
syntaxes/*.json linguist-language=JSON linguist-detectable=false
grammars/*.json linguist-language=JSON linguist-detectable=false
.github/linguist.yml linguist-language=YAML linguist-detectable=false

# ============================================
# Fichiers C du compilateur (vendored - exclus des stats)
# ============================================

# Tout le code C est marqué comme vendored
*.c linguist-vendored
*.h linguist-vendored
*.l linguist-vendored
*.y linguist-vendored
*.o linguist-generated

# ============================================
# Scripts et outils (vendored)
# ============================================

*.sh linguist-vendored
*.py linguist-vendored
Makefile linguist-vendored
*.mk linguist-vendored

# ============================================
# Configuration Vim (vendored)
# ============================================

*.vim linguist-vendored
*.vimrc linguist-vendored
*.snippets linguist-vendored

# ============================================
# Documentation (exclue des stats)
# ============================================

*.md linguist-documentation
docs/* linguist-documentation

# ============================================
# Exemples et tests (comptent comme Goscript)
# ============================================

exemples/*.gjs linguist-language=Goscript linguist-detectable=true
tests/*.gjs linguist-language=Goscript linguist-detectable=true
test_*.gjs linguist-language=Goscript linguist-detectable=true
*_test.gjs linguist-language=Goscript linguist-detectable=true
