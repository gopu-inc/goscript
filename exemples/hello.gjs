fn main() {
    // Programme simple d'affichage
    println("Hello, Goscript!")

    // Variables
    lt name = "World"
    println("Hello, " + name)

    // Opérations mathématiques
    lt a = 10
    lt b = 20
    println(a + b)

    // Boucle simple
    for i in [1, 2, 3, 4, 5] {
        println("Number: " + i)
    }
    
    ret 0
}

