// POST avec authentification
pub fn PostAuth(url: string, data: string, username: string, password: string) {
    lt cmd = "curl -s -X POST -u '" + username + ":" + password + "' -d '" + data + "' '" + url + "'"
    lt result = sysf(cmd)
    ret result
}
