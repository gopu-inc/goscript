// Goscript Example
// This file demonstrates Goscript syntax

fn main() {
    // Variables
    lt name = "Goscript"
    lt version = "2.0"
    lt year = 2026
    
    // Condition
    if year >= 2026 {
        println("Welcome to " + name + " " + version)
    }
    
    // Loop
    for i in [1, 2, 3, 4, 5] {
        println("Count: " + i)
    }
    
    // Return
    ret 0
}
